{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/memlume.mjs\"",
            "commandWindows": "node \"$env:PLUGIN_ROOT\\hooks\\memlume.mjs\"",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/memlume.mjs\"",
            "commandWindows": "node \"$env:PLUGIN_ROOT\\hooks\\memlume.mjs\"",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/memlume.mjs\"",
            "commandWindows": "node \"$env:PLUGIN_ROOT\\hooks\\memlume.mjs\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
