{
  "name": "@memlume/mcp-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "memlume-mcp": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build:dependencies": "pnpm --filter=@memlume/mcp-server... --filter=!@memlume/mcp-server --if-present run build",
    "build": "pnpm run build:dependencies && tsc -p tsconfig.json",
    "test": "pnpm run build:dependencies && vitest run",
    "typecheck": "pnpm run build:dependencies && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@memlume/contracts": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "vitest": "^4.1.10"
  }
}
