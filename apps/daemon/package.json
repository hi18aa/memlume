{
  "name": "@memlume/daemon",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build:console": "pnpm --filter @memlume/console build",
    "build": "pnpm run build:console && tsc -b --stopBuildOnErrors",
    "start": "node dist/start.js",
    "test": "pnpm run build && vitest run --pool=threads",
    "test:codex": "vitest --root ../.. run --exclude=.worktrees/** ../../adapters/codex/test/hook.test.ts",
    "typecheck": "tsc -b --stopBuildOnErrors"
  },
  "dependencies": {
    "@memlume/backup": "workspace:*",
    "@memlume/contracts": "workspace:*",
    "@memlume/context-resolver": "workspace:*",
    "@memlume/database": "workspace:*",
    "@memlume/event-journal": "workspace:*",
    "@memlume/memory-compiler": "workspace:*",
    "@memlume/retrieval": "workspace:*",
    "@memlume/shared-brains": "workspace:*",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^24.10.1",
    "vitest": "^4.1.10"
  }
}
